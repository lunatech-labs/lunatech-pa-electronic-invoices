                <ram:CalculatedAmount>49.50</ram:CalculatedAmount>
                <ram:TypeCode>VAT</ram:TypeCode>
                <ram:BasisAmount>900.00</ram:BasisAmount>
                <ram:CategoryCode>S</ram:CategoryCode>
