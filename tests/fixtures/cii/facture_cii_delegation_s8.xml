      </ram:SellerTradeParty>
      <!-- Acheteur = filiale du groupe -->
      <ram:BuyerTradeParty>
        <ram:Name>Hôtellerie du Sud-Ouest SAS</ram:Name>
        <ram:SpecifiedLegalOrganization>
          <ram:ID schemeID="0002">66677788899900</ram:ID>
