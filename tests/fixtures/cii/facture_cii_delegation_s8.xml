      <!-- Agent de l'acheteur (AB) = Service achats centralisé -->
      <ram:BuyerAgentTradeParty>
        <ram:Name>Service Achats Groupe Atlantique</ram:Name>
        <ram:SpecifiedLegalOrganization>
          <ram:ID schemeID="0002">55544433322299</ram:ID>
        </ram:SpecifiedLegalOrganization>
      </ram:BuyerAgentTradeParty>
    </ram:ApplicableHeaderTradeAgreement>

    <ram:ApplicableHeaderTradeDelivery>
