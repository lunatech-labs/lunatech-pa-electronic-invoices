        <ram:Name>Cabinet Comptable Gironde SARL</ram:Name>
        <ram:SpecifiedLegalOrganization>
          <ram:ID schemeID="0002">99988877766655</ram:ID>
        </ram:SpecifiedLegalOrganization>
        <ram:SpecifiedTaxRegistration>
          <ram:ID schemeID="VA">FR99988877766</ram:ID>
        </ram:SpecifiedTaxRegistration>
